#!/bin/sh
export RUNNER_ROOT="${RUNNER_ROOT:-/var/lib/1brc}"
export RUNNER_WORK_ROOT="${RUNNER_WORK_ROOT:-/var/lib/1brc/work}"
export RUNNER_IMAGE="${RUNNER_IMAGE:-onebrc-runner:ubuntu26}"
export RUNNER_PUBLIC_INPUT="${RUNNER_PUBLIC_INPUT:-/var/lib/1brc/data/public.csv}"
export RUNNER_PUBLIC_EXPECTED="${RUNNER_PUBLIC_EXPECTED:-/var/lib/1brc/data/public.expected}"
export RUNNER_PRIVATE_INPUT="${RUNNER_PRIVATE_INPUT:-/var/lib/1brc/data/private.csv}"
export RUNNER_PRIVATE_EXPECTED="${RUNNER_PRIVATE_EXPECTED:-/var/lib/1brc/data/private.expected}"
export BENCHMARK_ENVIRONMENT_ID="${BENCHMARK_ENVIRONMENT_ID:-local-ubuntu26-v1}"
export RUNNER_TIMEOUT_SECONDS="${RUNNER_TIMEOUT_SECONDS:-900}"
exec /opt/bun/bin/bun /opt/1brc/runner/gateway.js
