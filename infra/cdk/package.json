{
  "name": "@1brc/cdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap --app ''",
    "deploy": "cdk deploy",
    "test": "vitest run test/benchmark-stack.test.ts",
    "test:coverage": "vitest run test/benchmark-stack.test.ts --coverage --coverage.include='lib/**/*.ts' --coverage.reporter=text --coverage.reporter=json-summary --coverage.thresholds.lines=90"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.1130.0",
    "vitest": "^4.1.10"
  }
}
