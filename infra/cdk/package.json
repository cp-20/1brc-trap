{
  "name": "@1brc/cdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap --app ''",
    "deploy": "cdk deploy",
    "test": "bun test --isolate test/benchmark-stack.test.ts",
    "test:coverage": "bun test --isolate test/benchmark-stack.test.ts --coverage"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.1130.0"
  }
}
