{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["flock", "go", "pinact"],
  "ignoreDependencies": ["@typespec/http", "@typespec/openapi3"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts", "baselines/**/*.ts", "optimized/**/*.ts"]
    },
    "apps/mock-auth": {
      "entry": ["src/index.ts"]
    },
    "apps/runner": {
      "entry": ["image/measure.mjs"]
    },
    "infra/cdk": {
      "entry": ["bin/onebrc.ts"]
    }
  }
}
