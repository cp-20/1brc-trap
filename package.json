{
  "name": "1brc-trap",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/cdk"
  ],
  "engines": {
    "node": "24.18.0",
    "bun": "1.3.14"
  },
  "scripts": {
    "api:spec": "tsp compile packages/api --config packages/api/tspconfig.yaml",
    "api:client": "bun --cwd=packages/api run generate:client",
    "api:server": "go tool oapi-codegen -config apps/server/oapi-codegen.yaml packages/api/openapi.yaml",
    "api:generate": "bun run api:spec && bun run api:client && bun run api:server",
    "api:check": "bun run api:generate && git diff --exit-code -- packages/api/openapi.yaml packages/api/src/schema.ts apps/server/internal/api/api.gen.go",
    "build": "bun run --sequential --workspaces --if-present build",
    "dev": "bun run --parallel --filter @1brc/web --filter @1brc/server dev",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun run --parallel --workspaces --if-present typecheck",
    "test": "bun run --parallel --workspaces --if-present test",
    "test:coverage": "bun run --sequential --workspaces --if-present test:coverage",
    "db:check": "bun --cwd=apps/server run db:check",
    "db:migrate": "bun --cwd=apps/server run db:migrate",
    "knip": "knip",
    "infra:cdk:bootstrap": "bun --cwd=infra/cdk run bootstrap",
    "infra:cdk:synth": "bun --cwd=infra/cdk run synth",
    "infra:cdk:deploy": "bun --cwd=infra/cdk run deploy",
    "infra:ansible-config": "bun scripts/configure-ansible.ts",
    "runner:build": "bun --cwd=apps/runner run build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "ci:pin": "pinact run",
    "ci:pin:check": "pinact run --fix=false --no-api"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "@typespec/compiler": "^1.14.0",
    "@typespec/http": "^1.14.0",
    "@typespec/openapi3": "^1.14.0",
    "knip": "^6.26.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "^7.0.2",
    "zod": "^4.4.3"
  }
}
