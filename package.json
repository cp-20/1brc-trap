{
  "name": "1brc-trap",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @1brc/web --filter @1brc/server dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @1brc/server db:migrate",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
