{
  "name": "1brc-trap",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/cdk"
  ],
  "engines": {
    "node": "24.18.0",
    "bun": "1.3.14"
  },
  "scripts": {
    "build": "bun run --sequential --workspaces --if-present build",
    "dev": "bun run --parallel --filter @1brc/web --filter @1brc/server dev",
    "typecheck": "bun run --parallel --workspaces --if-present typecheck",
    "test": "bun run --parallel --workspaces --if-present test",
    "db:migrate": "bun run --filter @1brc/server db:migrate",
    "infra:ansible-config": "bun scripts/configure-ansible.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci:pin": "pinact run",
    "ci:pin:check": "pinact run --fix=false --no-api"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
