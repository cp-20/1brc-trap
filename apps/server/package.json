{
  "name": "@1brc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "bun src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "test:coverage": "vitest run src --coverage --coverage.include='src/**/*.ts' --coverage.exclude='src/**/*.test.ts' --coverage.reporter=text --coverage.reporter=json-summary --coverage.thresholds.lines=25"
  },
  "dependencies": {
    "@1brc/domain": "workspace:*",
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@hono/zod-validator": "^0.8.0",
    "busboy": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "mysql2": "^3.22.6",
    "neverthrow": "^8.2.0",
    "p-retry": "^7.1.1",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/ssh2": "^1.15.5",
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.10"
  }
}
