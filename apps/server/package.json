{
  "name": "@1brc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && bun build src/index.ts --target=bun --outdir=dist/bundle --sourcemap=linked --minify --external cpu-features",
    "start": "bun --smol dist/bundle/index.js",
    "profile:memory:server": "bun --inspect=127.0.0.1:16499/memory-profile scripts/profile-memory-server.ts",
    "profile:memory:load": "bun scripts/profile-memory-load.ts",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "bun src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p scripts/tsconfig.json",
    "test": "bun test --isolate src",
    "test:coverage": "bun test --isolate src --coverage"
  },
  "dependencies": {
    "@1brc/domain": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@remix-run/form-data-parser": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "mysql2": "^3.22.6",
    "neverthrow": "^8.2.0",
    "p-retry": "^7.1.1",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.5",
    "@testcontainers/mariadb": "^12.0.4",
    "drizzle-kit": "^0.31.10"
  }
}
