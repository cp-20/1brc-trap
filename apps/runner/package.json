{
  "name": "@1brc/runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun src/gateway.ts",
    "build": "tsc -p tsconfig.json && esbuild src/gateway.ts --bundle --platform=node --format=esm --outfile=dist/gateway.js",
    "start": "bun dist/gateway.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@1brc/domain": "workspace:*",
    "neverthrow": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "vitest": "^4.1.10"
  }
}
