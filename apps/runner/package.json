{
  "name": "@1brc/runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/gateway.ts",
    "build": "tsc -p tsconfig.json && esbuild src/gateway.ts --bundle --platform=node --format=esm --outfile=dist/gateway.js",
    "start": "node dist/gateway.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@1brc/contracts": "workspace:*",
    "neverthrow": "^8.2.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
