{
  "name": "@1brc/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run src --coverage --coverage.include='src/**/*.{ts,tsx}' --coverage.exclude='src/**/*.test.{ts,tsx}' --coverage.reporter=text --coverage.reporter=json-summary --coverage.thresholds.lines=4"
  },
  "dependencies": {
    "@1brc/domain": "workspace:*",
    "@1brc/server": "workspace:*",
    "@formkit/auto-animate": "^0.10.0",
    "@number-flow/react": "^0.6.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-select": "^2.2.6",
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@tanstack/react-query": "^5.101.2",
    "canvas-confetti": "^1.9.4",
    "hono": "^4.12.28",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "daisyui": "^5.6.16",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
